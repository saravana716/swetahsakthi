{
  "expo": {
    "name": "swarna_sakthi_app",
    "slug": "swarna_sakthi_app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.jpeg",
    "scheme": "swarnasakthiapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/Logo.jpeg",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saravanapriyan.swarna_sakthi_app",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Logo.jpeg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-video",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app requires access to photos to upload KYC documents.",
          "cameraPermission": "The app requires camera access to capture KYC documents."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow QR Scanning and Camera access for secure payments."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/Logo.jpeg",
          "color": "#EAB308",
          "sounds": []
        }
      ],
      "./plugins/withPayURepos"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "509dee85-8f1a-4da5-8006-aa7bb10a21f4"
      }
    },
    "owner": "saravanapriyan"
  }
}
